# Use ONE of these LLM providers (Groq recommended - most reliable free tier)

# Option 1: Groq (recommended) - Get key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Google Gemini - Get key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Provider selection (auto-detected from which key is set, or override manually)
# LLM_PROVIDER=groq
